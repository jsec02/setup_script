#!/usr/bin/env bash

# ================================================================================
# =                                    SETUP                                     =
# ================================================================================

set -euo pipefail

MACHINE=""

CURL="curl --location --fail --retry 3 --retry-delay 2 --retry-all-errors"
CURL_FILE="$CURL --output"

select_machine() {
    while true; do
        read -r -p "Select machine [wsl/pi/kali]: " MACHINE
        case "$MACHINE" in
            wsl | pi | kali) return ;;
            *) echo "Invalid option" >&2 ;;
        esac
    done
}

setup_locale() {
    # Enable en_US.UTF-8 UTF-8
    sudo sed --in-place 's/# en_US.UTF-8 UTF-8/en_US.UTF-8 UTF-8/' "/etc/locale.gen"

    # Compile en_US.UTF-8 UTF-8
    sudo locale-gen

    # Set en_US.UTF-8 UTF-8 as default locale
    echo "LANG=en_US.UTF-8" | sudo tee "/etc/locale.conf"
}

hush_login() {
    touch "$HOME/.hushlogin"
}

update_system() {
    case "$MACHINE" in
        wsl) sudo pacman -Syu --noconfirm ;;
        pi) sudo apt update && sudo apt upgrade --yes ;;
        kali) sudo apt update && sudo apt upgrade --yes ;;
    esac
}

bootstrap_yay() {
    sudo pacman -S --noconfirm git base-devel
    git clone https://aur.archlinux.org/yay.git "tmp/yay"
    (cd "tmp/yay" && makepkg --syncdeps --install --noconfirm) # Build arch package from source
    rm --recursive --force "tmp/yay"
}

install_pip2() {
    $CURL_FILE "/tmp/get-pip.py" \
        https://bootstrap.pypa.io/pip/2.7/get-pip.py
    python2 "/tmp/get-pip.py"
    rm --force "/tmp/get-pip.py"
}

install_packages() {
    case "$MACHINE" in
        # Get list of packages and pass it into corresponding package manager with xargs
        wsl) $CURL \
            https://raw.githubusercontent.com/jsec02/packages/master/wsl/yay.txt \
            | xargs --no-run-if-empty yay -S --noconfirm ;;

        pi)
            $CURL \
                https://raw.githubusercontent.com/jsec02/packages/master/pi/apt.txt \
                | xargs --no-run-if-empty sudo apt install --yes
            ;;

        kali)
            $CURL \
                https://raw.githubusercontent.com/jsec02/packages/master/kali/apt.txt \
                | xargs --no-run-if-empty sudo apt install --yes

            $CURL \
                https://raw.githubusercontent.com/jsec02/packages/master/kali/pip3.txt \
                | xargs --no-run-if-empty pip install --break-system-packages

            install_pip2
            $CURL \
                https://raw.githubusercontent.com/jsec02/packages/master/kali/pip2.txt \
                | xargs --no-run-if-empty pip2 install
            ;;
    esac
}

install_neovim() {
    case "$MACHINE" in
        pi)
            # Get latest neovim release, decompress, and extract
            $CURL \
                https://github.com/neovim/neovim/releases/latest/download/nvim-linux-arm64.tar.gz \
                | gzip --decompress --stdout \
                | sudo tar --extract --file=- --directory=/opt

            # Link binary to /usr/local/bin/nvim for PATH access
            sudo ln --symbolic --force "/opt/nvim-linux-arm64/bin/nvim" "/usr/local/bin/nvim"
            ;;

        kali)
            $CURL \
                https://github.com/neovim/neovim/releases/latest/download/nvim-linux-x86_64.tar.gz \
                | gzip --decompress --stdout \
                | sudo tar --extract --file=- --directory=/opt

            sudo ln --symbolic --force "/opt/nvim-linux-x86_64/bin/nvim" "/usr/local/bin/nvim"
            ;;
    esac
}

install_yazi() {
    case "$MACHINE" in
        pi)
            $CURL_FILE "/tmp/yazi-aarch64-unknown-linux-gnu.deb" \
                https://github.com/sxyazi/yazi/releases/latest/download/yazi-aarch64-unknown-linux-gnu.deb

            sudo apt install --yes "/tmp/yazi-aarch64-unknown-linux-gnu.deb"

            rm "/tmp/yazi-aarch64-unknown-linux-gnu.deb"
            ;;
        kali)
            $CURL_FILE "/tmp/yazi-x86_64-unknown-linux-gnu.deb" \
                https://github.com/sxyazi/yazi/releases/latest/download/yazi-x86_64-unknown-linux-gnu.deb

            sudo apt install --yes "/tmp/yazi-x86_64-unknown-linux-gnu.deb"

            rm "/tmp/yazi-x86_64-unknown-linux-gnu.deb"
            ;;
    esac
}

install_zellij() {
    case "$MACHINE" in
        pi)
            $CURL \
                "https://github.com/zellij-org/zellij/releases/latest/download/zellij-aarch64-unknown-linux-musl.tar.gz" \
                | gzip --decompress --stdout \
                | sudo tar --extract --file=- --directory=/usr/local/bin
            ;;
        kali)
            $CURL \
                "https://github.com/zellij-org/zellij/releases/latest/download/zellij-x86_64-unknown-linux-musl.tar.gz" \
                | gzip --decompress --stdout \
                | sudo tar --extract --file=- --directory=/usr/local/bin
            ;;
    esac
}

install_deskflow() {
    local version
    # Extract version from json
    version=$($CURL \
        https://api.github.com/repos/deskflow/deskflow/releases/latest \
        | grep '"tag_name"' \
        | cut --delimiter='"' --fields=4 \
        | tr --delete 'v')

    $CURL_FILE "/tmp/deskflow-${version}-debian-trixie-x86_64.deb" \
        "https://github.com/deskflow/deskflow/releases/latest/download/deskflow-${version}-debian-trixie-x86_64.deb"

    sudo apt install --yes "/tmp/deskflow-${version}-debian-trixie-x86_64.deb"

    rm "/tmp/deskflow-${version}-debian-trixie-x86_64.deb"
}

install_optional_software() {
    case "$MACHINE" in
        pi)
            install_neovim
            install_yazi
            install_zellij
            ;;
        kali)
            install_neovim
            install_yazi
            install_zellij
            install_deskflow
            ;;
    esac
}

prompt_for_secrets() {
    export RESTIC_REPOSITORY RESTIC_PASSWORD B2_ACCOUNT_ID B2_ACCOUNT_KEY

    while true; do
        read -r -p "Enter Restic repository: " RESTIC_REPOSITORY
        read -r -s -p "Enter Restic password: " RESTIC_PASSWORD && echo
        read -r -p "Enter B2 account ID: " B2_ACCOUNT_ID
        read -r -s -p "Enter B2 account key: " B2_ACCOUNT_KEY && echo

        # Exit loop on valid credentials
        restic snapshots &>/dev/null && return

        echo "Invalid credentials" >&2
    done
}

restore_from_restic() {
    local tags=(
        "ssh" "wsl" "nftables" "services" "bash" "databases" "direnv" "dotfiles"
        "helix" "history" "kakoune" "nvim" "powershell" "python" "sql"
        "sqliterc" "vault" "yazi" "wt" "zellij" "zsh" "lightdm" "autostart"
        "redshift" "wireguard" "navidrome" "packages" "fzf" "poc" "resolv" "networkmanager"
    )

    local sudo_tags=("wsl" "nftables" "services" "lightdm" "wireguard" "navidrome" "resolv" "networkmanager")

    # Loop over tags array and restore corresponding restic snapshots using sudo when necesary
    for tag in "${tags[@]}"; do
        local cmd="restic"
        [[ " ${sudo_tags[*]} " == *" $tag "* ]] && cmd="sudo --preserve-env restic"
        $cmd restore latest --tag "$tag" --host "$MACHINE" --target / 2>/dev/null || true
    done

    # Fix cache permissions after sudo restores
    sudo chown -R "$USER:$USER" "$HOME/.cache/restic"
}

setup_tldr() {
    tldr --update
}

decompress_rockyou() {
    [[ -f "/usr/share/wordlists/rockyou.txt.gz" ]] \
        && sudo gzip --decompress "/usr/share/wordlists/rockyou.txt.gz"
}

setup_uv() {
    $CURL https://astral.sh/uv/install.sh | sh
    export PATH="$HOME/.local/bin:$PATH" # Add uv to PATH for script duration
}

setup_venvs() {
    mkdir --parents "$HOME/venvs"

    local projects=(
        "alien_invasion" "data_visualization" "fish_tank" "infosec_forum"
        "ping" "port_scanner" "riven_sniper" "wfm"
    )

    # Loop over projects array, if directory exists on system, create virtual environment with corresponding requirements.txt file
    for project in "${projects[@]}"; do
        [[ -d "$HOME/python/projects/$project" ]] || continue
        uv venv "$HOME/venvs/$project" --python 3.13 # Pin version for pre-built wheels
        uv pip install --requirement "$HOME/python/projects/$project/requirements.txt" \
            --python "$HOME/venvs/$project/bin/python3"
    done
}

setup_zsa_qmk_firmware() {
    git clone https://github.com/zsa/qmk_firmware.git "$HOME/zsa_qmk_firmware"
    ln --symbolic "$HOME/qgmlwy" "$HOME/zsa_qmk_firmware/keyboards/zsa/voyager/keymaps/qgmlwy"

    # Pull in nested dependencies declared in .gitmodules
    (cd "$HOME/zsa_qmk_firmware" && git submodule update --init --recursive)

    # Setup virtual environment
    uv venv "$HOME/venvs/qmk"
    source "$HOME/venvs/qmk/bin/activate"
    uv pip install qmk
    qmk setup --home "$HOME/zsa_qmk_firmware"
    deactivate
}

setup_jellyfin() {
    sudo mkdir --parents /srv/jellyfin/{movies,shows,educational}
    sudo chown --recursive "$USER:$USER" "/srv/jellyfin"
    sudo mount --options remount,size=3G /tmp # Installer needs >= 2gb free space in /tmp
    $CURL https://repo.jellyfin.org/install-debuntu.sh | sudo bash
}

setup_navidrome() {
    sudo mkdir --parents "/srv/navidrome/music"
    sudo chown -R "$USER:$USER" "/srv/navidrome"

    local version
    # Extract version from json
    version=$($CURL \
        https://api.github.com/repos/navidrome/navidrome/releases/latest \
        | grep '"tag_name"' \
        | cut --delimiter='"' --fields=4 \
        | tr --delete 'v')

    $CURL_FILE "/tmp/navidrome_${version}_linux_arm64.deb" \
        "https://github.com/navidrome/navidrome/releases/download/v${version}/navidrome_${version}_linux_arm64.deb"

    sudo apt install --yes "/tmp/navidrome_${version}_linux_arm64.deb"

    rm "/tmp/navidrome_${version}_linux_arm64.deb"

    sudo systemctl enable --now navidrome
}

create_restic_repo() {
    restic init --repo "$HOME/restic"
}

setup_services() {
    sudo systemctl enable --now nftables

    case "$MACHINE" in
        wsl)
            sudo systemctl enable --now sshd
            ;;
        pi)
            sudo systemctl enable --now ssh
            sudo systemctl enable --now riven-sniper
            sudo systemctl enable --now qbittorrent-nox
            $CURL https://install.pi-hole.net | bash
            setup_jellyfin
            setup_navidrome
            ;;
        kali)
            sudo systemctl enable --now ssh
            ;;
    esac
}

disable_wifi_powersaving() {
    echo -e "[connection]\nwifi.powersave = 2" \
        | sudo tee "/etc/NetworkManager/conf.d/disable-wifi-powersaving.conf"
}

setup_wsl() {
    setup_locale
    update_system
    bootstrap_yay
    install_packages
    prompt_for_secrets
    restore_from_restic
    setup_tldr
    setup_venvs
    setup_zsa_qmk_firmware
    setup_services
}

setup_pi() {
    hush_login
    update_system
    install_packages
    install_optional_software
    prompt_for_secrets
    restore_from_restic
    create_restic_repo
    setup_tldr
    setup_uv
    setup_venvs
    setup_services
}

setup_kali() {
    hush_login
    update_system
    install_packages
    install_optional_software
    prompt_for_secrets
    restore_from_restic
    setup_tldr
    decompress_rockyou
    setup_services
    disable_wifi_powersaving
}

main() {
    if ((UID == 0)); then
        echo "Do not run this script as root" >&2
        exit 1
    fi

    select_machine

    # Grant wheel group passwordless sudo
    echo "%wheel ALL=(ALL:ALL) NOPASSWD: ALL" | sudo tee "/etc/sudoers.d/nopasswd"

    case "$MACHINE" in
        wsl) setup_wsl ;;
        pi) setup_pi ;;
        kali) setup_kali ;;
    esac

    # Revoke wheel group passwordless sudo
    sudo rm "/etc/sudoers.d/nopasswd"

    if command -v zsh >/dev/null; then
        chsh --shell "$(command -v zsh)"
        exec zsh
    fi
}

main "$@"
